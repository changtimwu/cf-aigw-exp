# The deployed Worker URL (provided by the gateway operator).
WORKER_URL=https://cf-aigw-exp-worker.changtimwu.workers.dev

# Per-user API key (issued by the gateway operator). Starts with aigwk_.
# This replaces the OpenAI API key in the existing app.
USER_API_KEY=

# Audio sample for demo-whisper (REST). Any wav/mp3/m4a/webm OpenAI accepts.
WHISPER_AUDIO_PATH=hello.wav

# Audio sample for demo-realtime (WebSocket). MUST be 24 kHz mono PCM16 raw.
# Convert any wav with:
#   ffmpeg -i input.wav -ar 24000 -ac 1 -f s16le hello-24k.pcm
REALTIME_AUDIO_PATH=hello-24k.pcm
