# Cloudflare API token (already present in your .env). Used only for
# management/diagnostic scripts; runtime probes don't need it.
CLOUDFLARE_API_TOKEN=

# === Direct mode (Phase 1) ===
# When CF_WORKER_URL is empty/unset, probes go straight to AI Gateway.
CF_ACCOUNT_ID=15bfe332876061d9a548a4f3d6835657
CF_AIGW_ID=aigw-exp-poc
CF_AIGW_TOKEN=

# Two sub-modes for direct:
#  (a) BYOK: leave OPENAI_API_KEY empty; AI Gateway substitutes its stored key.
#  (b) Pass-through: set OPENAI_API_KEY=sk-...; gateway forwards your key.
OPENAI_API_KEY=

# === Worker mode (Phase 2) ===
# When CF_WORKER_URL is set, probes hit the Worker instead of AI Gateway
# directly. The Worker validates USER_JWT and holds the gateway token
# server-side, so the desktop app no longer needs CF_AIGW_TOKEN.
#
# Local dev: run `npm run worker:dev`, then set CF_WORKER_URL=http://localhost:8787
# Production: set it to your deployed Worker URL.
CF_WORKER_URL=

# Per-user JWT (mint via: npm run issue:token -- --sub alice).
USER_JWT=

# Optional: path to an audio sample for the Whisper probe.
AUDIO_PATH=samples/hello.wav
