# Cloudflare API token (already present in your .env). Only used for management
# scripts in later phases; runtime probes don't need it.
CLOUDFLARE_API_TOKEN=

# Cloudflare account + AI Gateway identifiers (fill in after dashboard setup).
CF_ACCOUNT_ID=15bfe332876061d9a548a4f3d6835657
CF_AIGW_ID=

# Cloudflare AI Gateway authentication token. Created in the dashboard under
# the gateway's "Settings → Authentication". This is the credential the
# desktop app (or our probes) will send as `cf-aig-authorization`.
CF_AIGW_TOKEN=

# OpenAI key. Two ways to use this PoC:
#  (a) BYOK mode: leave OPENAI_API_KEY blank and configure the key inside
#      AI Gateway → Provider Keys. The gateway will substitute it.
#  (b) Pass-through mode: set OPENAI_API_KEY and the gateway just proxies.
#      Useful as a fallback if BYOK doesn't cover an endpoint (e.g. Whisper).
OPENAI_API_KEY=

# Optional: path to an audio sample for the Whisper probe.
AUDIO_PATH=samples/hello.wav
